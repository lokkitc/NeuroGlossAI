
# Минимально необходимые переменные
DATABASE_URL=sqlite+aiosqlite:///./data/neurogloss.db
SECRET_KEY=dev-secret-change-me

# Окружение и логирование
ENV=development
DEBUG=false
LOG_LEVEL=INFO

# AI (оставь пустым, если не используешь)
GROQ_API_KEY=

# CORS (список через запятую)
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# JWT (опционально)
# JWT_ISSUER=https://your-domain
# JWT_AUDIENCE=neuroglossai

# Uploads / S3 (опционально)
# UPLOADS_ENABLED=true
# UPLOAD_MAX_BYTES=5000000
# UPLOAD_PROVIDER=s3
# S3_ENDPOINT_URL=
# S3_BUCKET_NAME=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_BASE_URL=
# S3_OBJECT_ACL=public-read
# S3_RETURN_PRESIGNED_URL=true
# S3_PRESIGNED_URL_EXPIRES_SECONDS=3600

